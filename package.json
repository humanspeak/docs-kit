{
    "name": "@humanspeak/docs-kit",
    "version": "0.0.0",
    "description": "Shared documentation infrastructure for Humanspeak Svelte libraries",
    "type": "module",
    "scripts": {
        "build": "svelte-kit sync && svelte-package",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "npm run format && eslint . --fix",
        "prepublishOnly": "npm run build",
        "prepare": "npm run build && husky"
    },
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./hooks": {
            "types": "./dist/hooks/index.d.ts",
            "default": "./dist/hooks/index.js"
        },
        "./scripts/fetch-github-stats": {
            "types": "./dist/scripts/fetch-github-stats.d.ts",
            "default": "./dist/scripts/fetch-github-stats.js"
        },
        "./scripts/generate-sitemap-manifest": {
            "default": "./dist/scripts/generate-sitemap-manifest.js"
        },
        "./scripts/generate-social-cards": {
            "types": "./dist/scripts/generate-social-cards.d.ts",
            "default": "./dist/scripts/generate-social-cards.js"
        },
        "./actions": {
            "types": "./dist/actions/index.d.ts",
            "default": "./dist/actions/index.js"
        },
        "./fonts/*": "./dist/fonts/*",
        "./assets/*": "./dist/assets/*",
        "./styles/base.css": "./dist/styles/base.css",
        "./styles/fonts.css": "./dist/styles/fonts.css",
        "./styles/prose.css": "./dist/styles/prose.css",
        "./styles/theme.css": "./dist/styles/theme.css"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "peerDependencies": {
        "@humanspeak/svelte-motion": ">=0.1.0",
        "@lucide/svelte": ">=0.400.0",
        "@sveltejs/kit": "^2.0.0",
        "mode-watcher": "^1.0.0",
        "svelte": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "@humanspeak/svelte-motion": {
            "optional": false
        }
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^10.0.1",
        "@humanspeak/svelte-motion": "^0.1.27",
        "@lucide/svelte": "^0.576.0",
        "@sentry/sveltekit": "^9.31.0",
        "@sveltejs/adapter-auto": "^6.0.0",
        "@sveltejs/kit": "^2.53.3",
        "@sveltejs/package": "^2.4.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-svelte": "3.15.0",
        "globals": "^17.3.0",
        "husky": "^9.1.7",
        "mode-watcher": "^1.1.0",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-svelte": "^3.5.0",
        "svelte": "^5.53.5",
        "svelte-check": "^4.4.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1"
    },
    "volta": {
        "node": "24.13.0"
    },
    "dependencies": {
        "@humanspeak/svelte-satori-fix": "^0.0.3",
        "@resvg/resvg-js": "^2.6.2",
        "bits-ui": "^2.16.2",
        "clsx": "^2.1.1",
        "runed": "^0.37.1",
        "satori": "^0.24.1",
        "satori-html": "^0.3.2",
        "github-slugger": "^2.0.0",
        "tailwind-merge": "^3.5.0"
    }
}
