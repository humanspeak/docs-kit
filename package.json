{
    "name": "@humanspeak/docs-kit",
    "version": "0.0.0",
    "description": "Shared documentation infrastructure for Humanspeak Svelte libraries",
    "type": "module",
    "scripts": {
        "build": "svelte-kit sync && svelte-package",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "npm run format && eslint . --fix",
        "prepublishOnly": "npm run build",
        "prepare": "npm run build && husky"
    },
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./hooks": {
            "types": "./dist/hooks/index.d.ts",
            "default": "./dist/hooks/index.js"
        },
        "./server": {
            "types": "./dist/server/index.d.ts",
            "default": "./dist/server/index.js"
        },
        "./scripts/fetch-github-stats": {
            "types": "./dist/scripts/fetch-github-stats.d.ts",
            "default": "./dist/scripts/fetch-github-stats.js"
        },
        "./scripts/generate-sitemap-manifest": {
            "default": "./dist/scripts/generate-sitemap-manifest.js"
        },
        "./scripts/generate-social-cards": {
            "types": "./dist/scripts/generate-social-cards.d.ts",
            "default": "./dist/scripts/generate-social-cards.js"
        },
        "./actions": {
            "types": "./dist/actions/index.d.ts",
            "default": "./dist/actions/index.js"
        },
        "./vite": {
            "types": "./dist/vite/index.d.ts",
            "default": "./dist/vite/index.js"
        },
        "./blog": {
            "types": "./dist/blog/index.d.ts",
            "svelte": "./dist/blog/index.js",
            "default": "./dist/blog/index.js"
        },
        "./fonts/*": "./dist/fonts/*",
        "./assets/*": "./dist/assets/*",
        "./styles/base.css": "./dist/styles/base.css",
        "./styles/brutalist.css": "./dist/styles/brutalist.css",
        "./styles/fonts.css": "./dist/styles/fonts.css",
        "./styles/prose.css": "./dist/styles/prose.css",
        "./styles/prose-v2.css": "./dist/styles/prose-v2.css",
        "./styles/theme.css": "./dist/styles/theme.css"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "peerDependencies": {
        "@humanspeak/svelte-markdown": ">=1.0.0",
        "@humanspeak/svelte-motion": ">=0.1.0",
        "@lucide/svelte": ">=0.400.0",
        "@sveltejs/kit": "^2.0.0",
        "mode-watcher": "^1.0.0",
        "shiki": ">=3.0.0",
        "svelte": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "@humanspeak/svelte-markdown": {
            "optional": true
        },
        "@humanspeak/svelte-motion": {
            "optional": false
        },
        "shiki": {
            "optional": true
        }
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@humanspeak/svelte-markdown": "^1.5.3",
        "@humanspeak/svelte-motion": "^0.5.4",
        "@lucide/svelte": "^1.17.0",
        "@sentry/sveltekit": "^10.55.0",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.61.1",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@types/node": "^25.9.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-svelte": "3.18.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "mode-watcher": "^1.1.0",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-svelte": "^4.0.1",
        "shiki": "^4.1.0",
        "svelte": "^5.55.10",
        "svelte-check": "^4.4.8",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.14"
    },
    "packageManager": "pnpm@11.4.0",
    "volta": {
        "node": "24.16.0"
    },
    "dependencies": {
        "@humanspeak/svelte-satori-fix": "^0.0.6",
        "@resvg/resvg-js": "^2.6.2",
        "bits-ui": "^2.18.1",
        "clsx": "^2.1.1",
        "github-slugger": "^2.0.0",
        "runed": "^0.37.1",
        "satori": "^0.26.0",
        "satori-html": "^0.3.2",
        "tailwind-merge": "^3.6.0"
    }
}
