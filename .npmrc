engine-strict=false
# Don't fail the install when transitive dev deps (e.g. @sentry/cli) have
# build scripts pnpm 10 ignores by default. Their scripts staying off is
# fine — we don't need the @sentry/cli binary downloaded just to build
# this package — but the strict-dep-builds=true default turns that into
# a hard error, which breaks downstream consumers fetching us as a
# git-hosted dep (the inner `pnpm install` pnpm runs while preparing
# the package surfaces the same ERR_PNPM_IGNORED_BUILDS).
strict-dep-builds=false
